<Window x:Class="SurfaceMedic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:SurfaceMedic.App.Views"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="SurfaceMedic"
        Width="1440"
        Height="940"
        MinWidth="1120"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="254" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="{Binding ActivityLogHeight}" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="4" Background="{DynamicResource SidebarBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="78" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="30" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="18,0,14,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Width="34" Height="38" CornerRadius="8" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                        <Viewbox Width="23" Height="27"><Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.2" Fill="Transparent" Data="M12,2 L22,6 L22,15 C22,22 18,27 12,30 C6,27 2,22 2,15 L2,6 Z M12,8 L12,23 M6.5,15.5 L17.5,15.5" /></Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="SurfaceMedic" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Device health and thermal care" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding PrimaryNavigation}"
                         SelectedItem="{Binding SelectedPrimaryNavigation, Mode=TwoWay}"
                         Style="{StaticResource NavigationListBox}"
                         Margin="6,14,6,0"
                         automation:AutomationProperties.Name="Primary navigation">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="46">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ListBox Grid.Row="3"
                         ItemsSource="{Binding SecondaryNavigation}"
                         SelectedItem="{Binding SelectedSecondaryNavigation, Mode=TwoWay}"
                         Style="{StaticResource NavigationListBox}"
                         Margin="6,0,6,12"
                         automation:AutomationProperties.Name="Secondary navigation">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="44">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="4" Background="{DynamicResource SurfaceRaisedBrush}" Margin="0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessBrush}" Margin="16,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource WindowBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="28,0,18,0">
                    <TextBlock Text="{Binding PageTitle}" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="{Binding PageSubtitle}" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Button Content="Refresh diagnostics"
                            Command="{Binding RefreshDashboardCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,12,0"
                            Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Overview}"
                            automation:AutomationProperties.Name="Refresh device diagnostics" />
                    <ProgressBar Width="92" Height="4" IsIndeterminate="True" Margin="0,0,14,0" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Border Background="{DynamicResource SurfaceRaisedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding PrivilegeLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Content="&#xE921;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButton}" Width="46" Height="38" Click="MinimizeButton_OnClick" ToolTip="Minimize" automation:AutomationProperties.Name="Minimize window" />
                    <Button x:Name="MaximizeButton" Content="&#xE922;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButton}" Width="46" Height="38" Click="MaximizeButton_OnClick" ToolTip="Maximize" automation:AutomationProperties.Name="Maximize window" />
                    <Button Content="&#xE8BB;" FontFamily="Segoe Fluent Icons" Style="{StaticResource IconButton}" Width="46" Height="38" Click="CloseButton_OnClick" ToolTip="Close" automation:AutomationProperties.Name="Close window" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" ClipToBounds="True" Background="{DynamicResource WindowBrush}">
            <views:OverviewView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Overview}" />
            <views:ThermalView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Thermal}" />
            <views:PowerView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Power}" />
            <views:SoftwareView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Software}" />
            <views:MaintenanceView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Maintenance}" />
            <views:SettingsView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Settings}" />
            <views:AboutView Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=About}" />
        </Grid>

        <Border Grid.Row="2" Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="42" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Button Command="{Binding ToggleActivityLogCommand}" Style="{StaticResource SubtleButton}" HorizontalAlignment="Left" Padding="0" MinHeight="28" automation:AutomationProperties.Name="Toggle activity log">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D2;" FontFamily="Segoe Fluent Icons" FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,9,0" /><TextBlock Text="Activity log" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" /><TextBlock Text="{Binding ActivityLogStateLabel}" Margin="8,0,0,0" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" /></StackPanel>
                        </Button>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="Clear log" Style="{StaticResource SubtleButton}" Command="{Binding ClearLogCommand}" Margin="0,0,6,0" Padding="10,5" MinHeight="28" />
                            <Button Content="Copy log" Style="{StaticResource SubtleButton}" Command="{Binding CopyLogCommand}" Padding="10,5" MinHeight="28" />
                        </StackPanel>
                    </Grid>
                </Border>
                <TextBox x:Name="ActivityLogTextBox" Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" FontFamily="Cascadia Mono, Consolas" FontSize="12" Background="Transparent" BorderThickness="0" Padding="18,10" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextChanged="ActivityLogTextBox_OnTextChanged" automation:AutomationProperties.Name="Activity log output" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Grid.Column="1" Background="{DynamicResource SurfaceRaisedBrush}">
            <DockPanel Margin="14,0">
                <TextBlock Text="{Binding VersionLabel}" DockPanel.Dock="Right" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding BusyMessage}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="4" Grid.Column="1" Panel.ZIndex="50" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,88,24,0" MinWidth="320" MaxWidth="440" Background="{DynamicResource SurfaceRaisedBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8" Padding="14,12" Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ToastGlyph}" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1"><TextBlock Text="{Binding ToastTitle}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" /><TextBlock Text="{Binding ToastMessage}" Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" /></StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
