<UserControl x:Class="SurfaceMedic.App.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorder}" Padding="0" Margin="0,0,0,18">
                <Grid Height="116">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="20,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="46" Height="46" CornerRadius="10" Background="{DynamicResource SuccessSoftBrush}" VerticalAlignment="Top">
                            <TextBlock Text="&#xE83D;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding HealthTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding HealthMessage}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding HealthDetail}" Margin="0,5,0,0" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SuccessBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,1,0">
                        <Grid Margin="20,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="46" Height="46" CornerRadius="10" Background="{DynamicResource WarningSoftBrush}" VerticalAlignment="Top">
                                <TextBlock Text="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="22" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Attention recommended" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}" />
                                <TextBlock Text="{Binding AttentionMessage}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding AttentionDetail}" Margin="0,5,0,0" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Column="2" Margin="20,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="46" Height="46" CornerRadius="10" Background="{DynamicResource WarningSoftBrush}" VerticalAlignment="Top">
                            <TextBlock Text="&#xEDA2;" FontFamily="Segoe Fluent Icons" FontSize="23" Foreground="{DynamicResource WarningBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ConcernTitle}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ConcernMessage}" Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <Button Content="Review recommendation" Command="{Binding NavigateCommand}" CommandParameter="Maintenance" Style="{StaticResource SubtleButton}" HorizontalAlignment="Left" Margin="-10,2,0,0" Padding="10,4" MinHeight="28" automation:AutomationProperties.Name="Review health recommendation" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding OverviewCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding TargetPage}"
                                Margin="0,0,14,14"
                                Padding="0"
                                MinHeight="184"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                automation:AutomationProperties.Name="{Binding Title}">
                            <Grid Margin="18,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="34" Height="34" CornerRadius="8" Background="{DynamicResource AccentSoftBrush}">
                                        <TextBlock Text="{Binding Glyph}" FontFamily="Segoe Fluent Icons" FontSize="18" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="11,0,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" />
                                </Grid>
                                <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Margin="0,12,0,0" />
                                <StackPanel Grid.Row="2" Margin="0,14,0,0">
                                    <TextBlock Text="{Binding PrimaryText}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SecondaryText}" Margin="0,7,0,0" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="20" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
