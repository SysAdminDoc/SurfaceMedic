<UserControl x:Class="SurfaceMedic.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20,24,24" MaxWidth="980" HorizontalAlignment="Left">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="16" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Border Style="{StaticResource CardBorder}" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="104" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <Border Width="84" Height="84" CornerRadius="12" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Top">
                        <Viewbox Width="48" Height="54"><Path Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5" Fill="Transparent" Data="M12,2 L22,6 L22,15 C22,22 18,27 12,30 C6,27 2,22 2,15 L2,6 Z M12,8 L12,23 M6.5,15.5 L17.5,15.5" /></Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="SurfaceMedic" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Device health and thermal care" Margin="0,3,0,0" FontSize="15" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Border Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="6" Padding="9,4" HorizontalAlignment="Left" Margin="0,14,0,0"><TextBlock Text="{Binding VersionLabel}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" /></Border>
                        <TextBlock Margin="0,18,0,0" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="21" TextWrapping="Wrap" Text="SurfaceMedic brings Windows thermal history, power controls, software maintenance, and trusted repair tools into one local desktop workspace. Operations run asynchronously and stream their output into the in-app activity log." />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Runtime" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text=".NET 9 WPF desktop shell" Margin="0,12,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Asynchronous Windows process and PowerShell adapter" Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="Windows 10 and Windows 11, x64" Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="Portable PowerShell edition remains included" Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Trust and privacy" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Local-first diagnostics" Margin="0,12,0,0" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="No telemetry, accounts, or cloud dependency. System information remains on this PC unless you explicitly export a report." Margin="0,5,0,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="Licensed under the MIT License." Margin="0,10,0,0" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
