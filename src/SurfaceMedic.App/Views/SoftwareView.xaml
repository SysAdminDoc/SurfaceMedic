<UserControl x:Class="SurfaceMedic.App.Views.SoftwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardBorder}" Padding="18,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Recommended diagnostics" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Trusted tools for temperature, disk, and system telemetry." Margin="0,4,16,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>
                <UniformGrid Grid.Column="1" Columns="4">
                    <Button Command="{Binding InstallRecommendedToolCommand}" CommandParameter="REALiX.HWiNFO" Margin="0,0,8,0" Padding="12,9" automation:AutomationProperties.Name="Install HWiNFO64">
                        <StackPanel><TextBlock Text="HWiNFO64" FontWeight="SemiBold" HorizontalAlignment="Center" /><TextBlock Text="Thermal telemetry" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                    </Button>
                    <Button Command="{Binding InstallRecommendedToolCommand}" CommandParameter="CrystalDewWorld.CrystalDiskInfo" Margin="0,0,8,0" Padding="12,9" automation:AutomationProperties.Name="Install CrystalDiskInfo">
                        <StackPanel><TextBlock Text="CrystalDiskInfo" FontWeight="SemiBold" HorizontalAlignment="Center" /><TextBlock Text="Drive health" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                    </Button>
                    <Button Command="{Binding InstallRecommendedToolCommand}" CommandParameter="LibreHardwareMonitor.LibreHardwareMonitor" Margin="0,0,8,0" Padding="12,9" automation:AutomationProperties.Name="Install LibreHardwareMonitor">
                        <StackPanel><TextBlock Text="Libre Monitor" FontWeight="SemiBold" HorizontalAlignment="Center" /><TextBlock Text="Open telemetry" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                    </Button>
                    <Button Command="{Binding InstallRecommendedToolCommand}" CommandParameter="Microsoft.PowerToys" Padding="12,9" automation:AutomationProperties.Name="Install Microsoft PowerToys">
                        <StackPanel><TextBlock Text="PowerToys" FontWeight="SemiBold" HorizontalAlignment="Center" /><TextBlock Text="Windows utilities" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" /></StackPanel>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Height="40" Padding="38,8,10,8" automation:AutomationProperties.Name="Search packages" />
                            <TextBlock Text="&#xE721;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="13,0,0,0" HorizontalAlignment="Left" IsHitTestVisible="False" />
                            <TextBlock Text="Search by package name or ID..." Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" Margin="38,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding SearchQuery}" Value=""><Setter Property="Visibility" Value="Visible" /></DataTrigger><DataTrigger Binding="{Binding SearchQuery}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1" Content="Search winget" Style="{StaticResource PrimaryButton}" Command="{Binding SearchPackagesCommand}" Margin="10,0,8,0" />
                        <Button Grid.Column="2" Content="Install selected" Command="{Binding InstallSelectedPackageCommand}" />
                    </Grid>
                </Border>
                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding Packages}" SelectedItem="{Binding SelectedPackage}" AutoGenerateColumns="False" Visibility="{Binding Packages.Count, Converter={StaticResource PopulatedCountToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="PACKAGE ID" Binding="{Binding Id}" Width="300" />
                            <DataGridTextColumn Header="VERSION" Binding="{Binding Version}" Width="140" />
                            <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding Packages.Count, Converter={StaticResource EmptyCountToVisibilityConverter}}">
                        <TextBlock Text="&#xE71E;" FontFamily="Segoe Fluent Icons" FontSize="28" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Find trusted Windows packages" Margin="0,10,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Search winget to install software from configured sources." Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center"><TextBlock Text="Available updates" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" /><TextBlock Text="Review installed packages before applying upgrades." FontSize="12" Foreground="{DynamicResource TextMutedBrush}" /></StackPanel>
                        <Button Grid.Column="1" Content="Check for updates" Style="{StaticResource PrimaryButton}" Command="{Binding CheckUpdatesCommand}" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="Upgrade selected" Command="{Binding UpgradeSelectedPackageCommand}" Margin="0,0,8,0" />
                        <Button Grid.Column="3" Content="Upgrade all" Command="{Binding UpgradeAllPackagesCommand}" />
                    </Grid>
                </Border>
                <Grid Grid.Row="1">
                    <DataGrid ItemsSource="{Binding PackageUpdates}" SelectedItem="{Binding SelectedPackageUpdate}" AutoGenerateColumns="False" Visibility="{Binding PackageUpdates.Count, Converter={StaticResource PopulatedCountToVisibilityConverter}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="PACKAGE ID" Binding="{Binding Id}" Width="280" />
                            <DataGridTextColumn Header="INSTALLED" Binding="{Binding Version}" Width="120" />
                            <DataGridTextColumn Header="AVAILABLE" Binding="{Binding Available}" Width="120" />
                            <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PackageUpdates.Count, Converter={StaticResource EmptyCountToVisibilityConverter}}">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons" FontSize="27" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="Update status not checked" Margin="0,9,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="Run a check to see which installed packages have updates." Margin="0,4,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
