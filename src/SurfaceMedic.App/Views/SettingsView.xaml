<UserControl x:Class="SurfaceMedic.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,24" MaxWidth="980" HorizontalAlignment="Left">
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Appearance" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Choose the interface that is most comfortable for your environment. Both themes preserve status contrast and focus visibility." Margin="0,5,0,16" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <RadioButton GroupName="Theme" IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" Padding="14" HorizontalContentAlignment="Stretch">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="52" Height="38" CornerRadius="6" Background="#101923" BorderBrush="#2D9CFF" BorderThickness="1"><Grid Margin="7"><Grid.RowDefinitions><RowDefinition Height="6" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Background="#253446" CornerRadius="2" /><Border Grid.Row="1" Background="#182535" CornerRadius="2" Margin="0,5,0,0" /></Grid></Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="Dark" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" /><TextBlock Text="Graphite surfaces with a calm blue accent" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" /></StackPanel>
                            </Grid>
                        </RadioButton>
                        <RadioButton Grid.Column="2" GroupName="Theme" IsChecked="{Binding IsLightTheme, Mode=TwoWay}" Padding="14" HorizontalContentAlignment="Stretch">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="64" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="52" Height="38" CornerRadius="6" Background="#F5F7FA" BorderBrush="#1677C8" BorderThickness="1"><Grid Margin="7"><Grid.RowDefinitions><RowDefinition Height="6" /><RowDefinition Height="*" /></Grid.RowDefinitions><Border Background="#D7E0EA" CornerRadius="2" /><Border Grid.Row="1" Background="#FFFFFF" CornerRadius="2" Margin="0,5,0,0" /></Grid></Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="Light" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" /><TextBlock Text="Bright surfaces with the same semantic colors" Margin="0,3,0,0" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" /></StackPanel>
                            </Grid>
                        </RadioButton>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Activity log" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Keep the operational log expanded when SurfaceMedic starts. The log contains command output and recovery details without opening separate console windows." Margin="0,5,24,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleButton Grid.Column="1" Content="Expanded at startup" IsChecked="{Binding IsActivityLogExpanded, Mode=TwoWay}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Diagnostics and recovery" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Crash reports and session logs are stored locally under your Windows profile. SurfaceMedic does not upload diagnostic data." Margin="0,5,24,0" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding LogsDirectory}" Margin="0,8,0,0" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Open logs folder" Command="{Binding OpenLogsFolderCommand}" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
